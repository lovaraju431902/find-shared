{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,              // optional, but good for debugging types
    "emitDeclarationOnly": true,         // ← important if only types/build d.ts files (no JS emit needed if separate bundler use chestunnav)
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "importHelpers": true,
    "lib": ["ES2022", "DOM"],            // updated to modern
    "module": "NodeNext",                // ← key change (or ESNext if bundler)
    "moduleResolution": "NodeNext",      // ← key change (or "bundler")
    "target": "ES2022",                  // much better than es5
    "strict": true,
    "noEmitOnError": true,
    "outDir": "build",                   // or "dist"
    "rootDir": "./src",
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "pretty": true,
    "resolveJsonModule": true,
    "skipLibCheck": true                 // add if you have many deps
  },
  "include": ["src"],
  "exclude": ["node_modules", "build", "dist"]
} 